# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*
*/target/*

# Helm — override files containing real secrets (not the committed test values)
# If you create environment-specific secret files outside the committed values files,
# name them *.secret.yaml and they will never be committed.
helm/**/*.secret.yaml

# Skaffold local state
.skaffold/

# Icon
Icon